# =============================================================
# BUDGET TRACKER - Environment Variables
# =============================================================
# Copy this file to .env.local and fill in your values.
# For Vercel deployment, add these in the Vercel dashboard.
# =============================================================

# -------------------------------------------------------------
# DATABASE (Prisma Postgres via db.prisma.io)
# -------------------------------------------------------------
# Your full connection URL from the Prisma Console / Vercel dashboard.
# In Prisma 7, this single URL is used for both runtime AND migrations.
DATABASE_URL="postgres://USER:PASSWORD@db.prisma.io:5432/postgres?sslmode=require"
